{
    "name": "transport-support-application",
    "version": "1.0.0",
    "description": "",
    "main": "src/index.ts",
    "scripts": {
        "start": "yarn barrels && nodemon --exec ts-node -r tsconfig-paths/register src/server.ts",
        "dev": "yarn barrels && nodemon --exec ts-node -r tsconfig-paths/register src/server.ts",
        "build": "tsc",
        "barrels": "barrelsby --config .barrelsby.json -q",
        "format": "prettier '**/*.{tsx,ts,js,json,md,yml,yaml}' --write",
        "lint": "eslint '**/*.{tsx,ts,js}' --fix",
        "db:migrate": "npx prisma migrate dev",
        "db:reset": "npx prisma migrate reset --force",
        "db:deploy": "npx prisma migrate deploy",
        "db:generate": "npx prisma generate",
        "prepare": "husky install"
    },
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@prisma/client": "^5.15.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/jsonwebtoken": "^9.0.6",
        "@types/nodemailer": "^6.4.13",
        "@types/otp-generator": "^4.0.2",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.6",
        "bcryptjs": "^2.4.3",
        "chalk": "^4.1.2",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "install": "^0.13.0",
        "joi": "^17.13.1",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.3.4",
        "nodemailer": "^6.9.13",
        "nodemon": "^3.1.0",
        "npm": "^10.8.0",
        "otp-generator": "^4.0.1",
        "prisma": "^5.15.0",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.0",
        "tsconfig-paths": "^4.2.0",
        "ts-node": "^10.9.2",
        "barrelsby": "^2.8.1"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.3.0",
        "@commitlint/config-conventional": "^19.2.2",
        "@types/express": "^4.17.21",
        "@typescript-eslint/eslint-plugin": "^6.2.1",
        "@typescript-eslint/parser": "^6.2.1",
        "eslint": "^8.46.0",
        "eslint-config-prettier": "^9.0.0",
        "eslint-plugin-react-hooks": "^4.6.2",
        "husky": "^8.0.0",
        "lint-staged": "^15.2.7",
        "prettier": "3.3.2",
        "typescript": "^5.4.5",
        "winston": "^3.13.0"
    }
}
