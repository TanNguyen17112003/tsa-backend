{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "dist",
    "moduleResolution": "node",
    "noResolve": false,
    "preserveConstEnums": true,
    "sourceMap": true,
    "noEmit": false,
    "emitDeclarationOnly": false,
    "inlineSources": true,
    "removeComments": false
  },
  "exclude": [
    "**/*.spec.ts",
    "prisma",
    "**/*.test.ts",
    "**/*.config.js",
    "node_modules",
    "dist",
    "coverage"
  ]
}
